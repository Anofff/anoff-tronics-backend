# App
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Database (Neon / Railway PostgreSQL)
DATABASE_URL="postgresql://user:pass@host/anoff?sslmode=require"

# Redis (Upstash / Railway — use rediss:// for TLS)
REDIS_URL="rediss://default:pass@host:6379"

# JWT
JWT_SECRET=your-strong-secret-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_JWT_SECRET=separate-admin-secret-here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret

# Paystack
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# Resend (email)
RESEND_API_KEY=re_...
EMAIL_FROM=Anoff Mobiles <noreply@anoffmobiles.com>
